---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Venn from '../components/Venn.jsx';

const cases = await getCollection('cases');
const sorted = cases.sort((a, b) => a.data.order - b.data.order);
// List reads reverse-chronologically (newest case first); the Venn keeps numeric order.
const newestFirst = [...sorted].reverse();

const domainLabels: Record<string, string> = {
  'learning-design': 'Learning Design',
  'engineering': 'Engineering',
  'leadership': 'Leadership',
};
---

<Layout
  title="Practice — George Mitchell Payne"
  description="The learning engineer practice: where learning design, engineering, and leadership intersect."
>
  <div class="container">

    <!-- ── Header ────────────────────────────────────── -->
    <section class="practice-header">
      <p class="telemetry section-label">// practice</p>
      <h1 class="practice-title">The learning engineer</h1>
      <p class="practice-lead">
        A learning engineer sits at the intersection of three disciplines.
        Each case study maps to one or more domains. The center cases are the pivot proof.
      </p>
    </section>

    <!-- ── Venn ──────────────────────────────────────── -->
    <section class="venn-section" aria-label="Domain Venn diagram">
      <Venn client:visible cases={sorted.map(c => ({ title: c.data.title, slug: c.data.slug, domains: c.data.domains }))} />
    </section>

    <!-- ── Cases ─────────────────────────────────────── -->
    <section class="cases-section" aria-label="Case studies">
      <p class="telemetry section-label">// cases</p>

      {sorted.length === 0 ? (
        <p class="cases-empty">
          Cases are being written and will appear here as they are completed.
        </p>
      ) : (
        <ul class="cases-list" role="list">
          {newestFirst.map(c => (
            <li class="case-row" id={c.data.slug}>
              <div class="case-meta">
                <span class="telemetry case-order">{String(c.data.order).padStart(2, '0')}</span>
                {c.data.timeline && (
                  <span class="telemetry case-timeline">{c.data.timeline}</span>
                )}
                {c.data.center && (
                  <span class="case-center-badge">center</span>
                )}
              </div>
              <div class="case-body">
                <h2 class="case-title">
                  <a href={`/practice/${c.data.slug}`} class="case-title-link">
                    {c.data.title}
                  </a>
                </h2>
                <p class="case-situation">{c.data.situation}</p>
                <div class="case-footer">
                  <ul class="case-domains" role="list" aria-label="Domains">
                    {c.data.domains.map(d => (
                      <li class={`domain-tag is-${d.split('-')[0]}`}>
                        {domainLabels[d] ?? d}
                      </li>
                    ))}
                  </ul>
                  <a href={`/practice/${c.data.slug}`} class="case-read-link" aria-label={`Read full case: ${c.data.title}`}>
                    read case →
                  </a>
                </div>
              </div>
            </li>
          ))}
        </ul>
      )}
    </section>

  </div>
</Layout>

<style>
  /* ── Header ───────────────────────────────────────── */
  .practice-header {
    padding-top: var(--space-4);
    margin-bottom: var(--space-12);
    max-width: var(--content-width);
  }

  .section-label {
    margin-bottom: var(--space-4);
  }

  .practice-title {
    font-size: var(--text-4xl);
    font-weight: 600;
    line-height: 1.1;
    margin-bottom: var(--space-4);
  }

  .practice-lead {
    font-size: var(--text-lg);
    color: var(--color-ink-muted);
    line-height: 1.65;
    max-width: 44ch;
  }

  /* ── Venn ─────────────────────────────────────────── */
  .venn-section {
    margin-bottom: var(--space-16);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-12);
  }

  :global(.venn-wrap) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: start;
    max-width: 56rem;
  }

  :global(.venn-left) {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    min-width: 0; /* prevent SVG column from expanding beyond 1fr */
  }

  :global(.venn-svg) {
    width: 100%;
    height: auto;
    display: block;
    /* Clip to viewBox so text/stroke bleeds can't cause layout reflow */
    overflow: hidden;
  }

  /* All SVG children are purely visual — events handled at container level */
  :global(.venn-svg *) {
    pointer-events: none;
  }

  :global(.venn-hint) {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    opacity: 0.6;
    text-align: center;
  }

  :global(.venn-panel) {
    min-height: 5rem;
    padding-top: var(--space-3);
    min-width: 0; /* allow nowrap case titles to ellipsis rather than blow out the column */
  }

  :global(.venn-panel-label) {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.04em;
    margin-bottom: var(--space-4);
  }

  :global(.venn-lock-hint) {
    font-weight: 400;
    opacity: 0.5;
    font-size: var(--text-xs);
  }

  :global(.venn-case-list) {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  :global(.venn-case-link) {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
  }

  :global(.venn-case-link:hover) {
    color: var(--color-ink);
    text-decoration: underline;
  }

  @media (max-width: 44em) {
    :global(.venn-wrap) {
      grid-template-columns: 1fr;
    }
  }

  /* ── Cases ────────────────────────────────────────── */
  .cases-section {
    margin-bottom: var(--space-16);
  }

  .cases-empty {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    padding: var(--space-8) 0;
    border-top: 1px solid var(--color-border);
  }

  .cases-list {
    list-style: none;
    padding: 0;
  }

  .case-row {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: var(--space-6);
    padding-block: var(--space-8);
    border-top: 1px solid var(--color-border);
    align-items: start;
  }

  .case-row:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .case-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: 0.25rem;
  }

  .case-order {
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
  }

  .case-timeline {
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
    letter-spacing: 0.04em;
  }

  .case-center-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
    letter-spacing: 0.05em;
  }

  .case-title {
    font-size: var(--text-xl);
    font-weight: 600;
    line-height: 1.25;
    margin-bottom: var(--space-3);
  }

  .case-title-link {
    color: var(--color-ink);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .case-title-link:hover {
    color: var(--color-accent);
  }

  .case-situation {
    font-size: var(--text-base);
    color: var(--color-ink-muted);
    line-height: 1.65;
    margin-bottom: var(--space-4);
    max-width: 60ch;
  }

  .case-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .case-domains {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .case-read-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .case-read-link:hover {
    color: var(--color-accent);
  }

  .domain-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    padding: 0.15em 0.6em;
    border-radius: 3px;
  }

  .is-learning {
    background: var(--color-ld-wash);
    color: var(--color-ld);
  }

  .is-engineering {
    background: var(--color-eng-wash);
    color: var(--color-eng);
  }

  .is-leadership {
    background: var(--color-gov-wash);
    color: var(--color-gov);
  }

  @media (max-width: 36em) {
    .case-row {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
  }
</style>
