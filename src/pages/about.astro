---
import Layout from '../layouts/Layout.astro';

const timeline = [
  {
    period: 'July 2026 →',
    role: 'Master of Science of AI Engineering',
    org: 'Quantic School of Business and Technology',
    note: 'formalizing the practice',
  },
  {
    period: '2023 – present',
    role: 'Lead Learning Designer',
    org: 'Boundless Learning',
    note: '',
  },
  {
    period: '2022 – 2023',
    role: 'Senior Instructional Design and Development Analyst',
    org: 'Pearson Online Learning Services',
    note: '',
  },
  {
    period: '2019 – 2022',
    role: 'Instructional Design and Development Analyst',
    org: 'Pearson Online Learning Services',
    note: '',
  },
  {
    period: '2017 – 2019',
    role: 'Instructional Designer',
    org: 'New England College of Business',
    note: '',
  },
  {
    period: '2016 – 2017',
    role: 'Project Assistant, Design Lab',
    org: 'Center for Social Innovation',
    note: '',
  },
  {
    period: '2015 – 2016',
    role: 'Program Support Coordinator',
    org: 'WorldTeach',
    note: '',
  },
  {
    period: '2013 – 2015',
    role: 'Master of Public Administration & Master of Arts of International Education Management',
    org: 'Middlebury Institute of International Studies',
    note: '',
  },
  {
    period: '2008 – 2013',
    role: 'Bachelor of Arts of International Area Studies',
    org: 'Drexel University',
    note: '',
  },
];
---

<Layout
  title="About — George Mitchell Payne"
  description="Learning engineer with 10 years of experience building learning systems with code and AI."
>
  <div class="container">

    <!-- ── Bridge narrative ──────────────────────────── -->
    <section class="about-hero">
      <p class="telemetry section-label">// about</p>
      <h1 class="about-name">George Mitchell Payne</h1>
      <p class="about-role">Learning Engineer</p>
    </section>

    <section class="about-narrative">
      <p class="narrative-body">
        I'm a learning engineer. For the past 10 years, I have cultivated learning design
        expertise by building hundreds of learning objects and assessments, revising over
        100 distinct course offerings, and producing learning solutions for high-profile
        clients, including the United Nations. My expertise ranges from multimedia and
        video production to data-driven learning design, to learning experience architecture
        and AI-assisted coding.
      </p>
      <p class="narrative-body">
        Every year for the last four years, I have woven AI into the practice of learning
        design. Because I think in systems, my background in learning ecosystem development
        shapes how I build with AI: context-forward and framework-dependent.
      </p>
      <p class="narrative-body">
        I am formalizing my learning engineering practice through a 1-year MS of AI
        Engineering program with Quantic School of Business and Technology starting in
        July 2026. By designing-in-public as a practice, my short-term goal is to bridge
        my experience as a learning architect into roles where I build custom, scalable
        learning solutions that ship. My long-term goal is to lead L&amp;D initiatives
        and cross-functional personnel through the AI era.
      </p>
    </section>

    <!-- ── Condensed timeline ────────────────────────── -->
    <section class="about-timeline" aria-label="Experience timeline">
      <p class="telemetry section-label">// experience</p>
      <ol class="timeline-list" reversed>
        {timeline.map(({ period, role, org, note }) => (
          <li class="timeline-item">
            <span class="timeline-period">{period}</span>
            <span class="timeline-content">
              <span class="timeline-role">{role}</span>
              {' · '}
              <span class="timeline-org">{org}</span>
              {note && <span class="timeline-note"> — {note}</span>}
            </span>
          </li>
        ))}
      </ol>
    </section>

    <!-- ── Links ─────────────────────────────────────── -->
    <section class="about-links" aria-label="Find me online">
      <p class="telemetry section-label">// find me</p>
      <ul class="links-list" role="list">
        <li>
          <a href="https://github.com/GPayne12" rel="noopener noreferrer">
            GitHub — GPayne12
          </a>
        </li>
        <li>
          <a href="https://www.linkedin.com/in/georgemitchellpayne" rel="noopener noreferrer">
            LinkedIn — georgemitchellpayne
          </a>
        </li>
      </ul>
    </section>

  </div>
</Layout>

<style>
  /* ── Layout ───────────────────────────────────────── */
  .container > section {
    max-width: var(--content-width);
  }

  .section-label {
    margin-bottom: var(--space-4);
  }

  /* ── Hero ─────────────────────────────────────────── */
  .about-hero {
    padding-top: var(--space-4);
    margin-bottom: var(--space-12);
  }

  .about-name {
    font-size: var(--text-4xl);
    font-weight: 600;
    line-height: 1.1;
    margin-bottom: var(--space-2);
  }

  .about-role {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--color-telemetry);
    letter-spacing: 0.02em;
  }

  /* ── Narrative ────────────────────────────────────── */
  .about-narrative {
    margin-bottom: var(--space-16);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .narrative-body {
    font-size: var(--text-lg);
    line-height: 1.75;
    color: var(--color-ink);
  }

  /* ── Timeline ─────────────────────────────────────── */
  .about-timeline {
    margin-bottom: var(--space-16);
  }

  .timeline-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: var(--space-4);
    padding-block: var(--space-4);
    border-top: 1px solid var(--color-border);
    align-items: baseline;
  }

  .timeline-item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .timeline-period {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
    padding-top: 0.2em;
  }

  .timeline-role {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-ink);
  }

  .timeline-org {
    font-size: var(--text-base);
    color: var(--color-ink-muted);
  }

  .timeline-note {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-telemetry);
  }

  @media (max-width: 36em) {
    .timeline-item {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }

  /* ── Links ────────────────────────────────────────── */
  .about-links {
    margin-bottom: var(--space-16);
  }

  .links-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .links-list a {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

</style>
