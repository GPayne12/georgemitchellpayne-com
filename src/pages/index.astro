---
import Layout from '../layouts/Layout.astro';
import GitHubActivity from '../components/GitHubActivity.astro';
---

<Layout title="Learning Engineer" description="George Mitchell Payne — learning engineer building learning systems with code and AI.">

  <!-- ── Hero ───────────────────────────────────────── -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <h1 class="font-display hero-headline">
          I'm a learning engineer.
        </h1>
        <p class="hero-body">
          For the past 10 years, I have cultivated learning design expertise by building
          hundreds of learning objects and assessments, revising over 100 distinct course
          offerings, and producing learning solutions for high-profile clients, including
          the United Nations. My expertise ranges from multimedia and video production to
          data-driven learning design, to learning experience architecture and AI-assisted
          coding. I have been building learning solutions for a decade. Now I build them
          with code and AI.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Audience doors ────────────────────────────── -->
  <section class="doors" aria-label="Explore by audience">
    <div class="container">
      <div class="doors-grid">

        <a href="/builds" class="door" aria-label="Explore builds — for engineering reviewers">
          <p class="telemetry door-label">// for AI + engineering reviewers</p>
          <h2 class="door-heading">Builds</h2>
          <p class="door-body">
            Every year for the last four years, I have woven AI into the practice of
            learning design. My tools may be limited in my 9-5, but my GitHub tells
            another story.
          </p>
          <span class="door-cta" aria-hidden="true">View builds →</span>
        </a>

        <a href="/practice" class="door" aria-label="Explore practice — for L&D leadership">
          <p class="telemetry door-label">// for L&D leadership</p>
          <h2 class="door-heading">Practice</h2>
          <p class="door-body">
            After 10 years of learning design experience, my short-term goal is to
            bridge my experience as a learning architect into roles where I build
            custom, scalable learning solutions that ship.
          </p>
          <span class="door-cta" aria-hidden="true">View practice →</span>
        </a>

      </div>
    </div>
  </section>

  <GitHubActivity />

</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────── */
  .hero {
    padding-top: var(--space-20);
    padding-bottom: var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }

  .hero-inner {
    max-width: 44rem;
  }

  .hero-headline {
    font-size: var(--text-5xl);
    line-height: 1.05;
    margin-bottom: var(--space-8);
  }

  .hero-body {
    font-size: var(--text-lg);
    line-height: 1.75;
    color: var(--color-ink);
    max-width: 38rem;
  }

  /* ── Doors ────────────────────────────────────────── */
  .doors {
    padding-block: var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }

  .doors-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }

  .door {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-8);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    text-decoration: none;
    color: var(--color-ink);
    transition: border-color var(--duration-base) var(--ease-standard),
                background var(--duration-base) var(--ease-standard);
  }

  .door:hover {
    border-color: var(--color-accent);
    background: var(--color-bg);
  }

  .door-label {
    font-size: var(--text-xs);
  }

  .door-heading {
    font-size: var(--text-2xl);
    font-weight: 600;
    line-height: 1.2;
    margin: 0;
  }

  .door-body {
    font-size: var(--text-base);
    line-height: 1.65;
    color: var(--color-ink-muted);
    flex: 1;
  }

  .door-cta {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-accent);
    margin-top: var(--space-2);
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .door:hover .door-cta {
    color: var(--color-accent-hover);
  }

  @media (max-width: 40em) {
    .doors-grid {
      grid-template-columns: 1fr;
    }
  }

</style>
