---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('log', ({ data }) => !data.draft);
  const sorted = entries.sort((a, b) => a.data.order - b.data.order);
  const entrySlug = (id: string) => id.replace(/\.(md|mdx)$/, '');
  return sorted.map((entry, i) => ({
    params: { slug: entrySlug(entry.id) },
    props: {
      entry,
      prev: i > 0
        ? { title: sorted[i - 1].data.title, slug: entrySlug(sorted[i - 1].id) }
        : null,
      next: i < sorted.length - 1
        ? { title: sorted[i + 1].data.title, slug: entrySlug(sorted[i + 1].id) }
        : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout
  title={`${entry.data.title} — Build Log`}
  description={entry.data.assessment ?? `Build log entry: ${entry.data.title}`}
>
  <div class="container">
    <article class="log-entry" aria-label={entry.data.title}>

      <!-- ── Header ──────────────────────────────────── -->
      <header class="entry-header">
        <a href="/log" class="back-link">← Log</a>
        <div class="entry-meta">
          <span class="telemetry entry-order">session {String(entry.data.order).padStart(2, '0')}</span>
          <span class="entry-date">{formatDate(entry.data.date)}</span>
        </div>
        <h1 class="entry-title">{entry.data.title}</h1>
        {entry.data.tags.length > 0 && (
          <ul class="entry-tags" role="list" aria-label="Tags">
            {entry.data.tags.map(tag => (
              <li class="entry-tag">{tag}</li>
            ))}
          </ul>
        )}
      </header>

      <!-- ── Structured summary (if present) ─────────── -->
      {(entry.data.objective || entry.data.activity || entry.data.assessment) && (
        <aside class="entry-summary" aria-label="Session summary">
          {entry.data.objective && (
            <div class="summary-row">
              <p class="telemetry summary-label">// objective</p>
              <p class="summary-body">{entry.data.objective}</p>
            </div>
          )}
          {entry.data.activity && (
            <div class="summary-row">
              <p class="telemetry summary-label">// activity</p>
              <p class="summary-body">{entry.data.activity}</p>
            </div>
          )}
          {entry.data.assessment && (
            <div class="summary-row">
              <p class="telemetry summary-label">// assessment</p>
              <p class="summary-body">{entry.data.assessment}</p>
            </div>
          )}
        </aside>
      )}

      <!-- ── Body ────────────────────────────────────── -->
      <div class="entry-body prose">
        <Content />
      </div>

      <!-- ── Previous / next navigation ──────────────── -->
      {(prev || next) && (
        <nav class="entry-nav" aria-label="Log entry navigation">
          {prev ? (
            <a href={`/log/${prev.slug}`} class="entry-nav-link nav-prev">
              <span class="telemetry nav-label">← previous</span>
              <span class="nav-title">{prev.title}</span>
            </a>
          ) : (
            <span class="entry-nav-spacer" />
          )}
          {next && (
            <a href={`/log/${next.slug}`} class="entry-nav-link nav-next">
              <span class="telemetry nav-label">next →</span>
              <span class="nav-title">{next.title}</span>
            </a>
          )}
        </nav>
      )}

    </article>
  </div>
</Layout>

<style>
  /* ── Layout ───────────────────────────────────────── */
  .log-entry {
    max-width: var(--content-width);
    padding-top: var(--space-4);
    padding-bottom: var(--space-16);
  }

  /* ── Header ───────────────────────────────────────── */
  .entry-header {
    margin-bottom: var(--space-10);
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: var(--space-6);
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .entry-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .entry-order {
    font-size: var(--text-xs);
  }

  .entry-date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
  }

  .entry-title {
    font-size: var(--text-3xl);
    font-weight: 600;
    line-height: 1.15;
    margin-bottom: var(--space-5);
  }

  .entry-tags {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .entry-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 0.15em 0.55em;
    border-radius: 3px;
    letter-spacing: 0.02em;
  }

  /* ── Structured summary ───────────────────────────── */
  .entry-summary {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: var(--space-6);
    margin-bottom: var(--space-10);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .summary-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .summary-label {
    font-size: var(--text-xs);
    margin: 0;
  }

  .summary-body {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--color-ink-muted);
  }

  /* ── Prose body ───────────────────────────────────── */
  .prose {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--color-ink);
  }

  .prose :global(h2) {
    font-size: var(--text-xl);
    font-weight: 600;
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
    line-height: 1.25;
  }

  .prose :global(h3) {
    font-size: var(--text-lg);
    font-weight: 600;
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .prose :global(p) {
    margin-bottom: var(--space-5);
  }

  .prose :global(a) {
    color: var(--color-accent);
  }

  .prose :global(strong) {
    font-weight: 600;
    color: var(--color-ink);
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: var(--space-6);
    margin-bottom: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  /* Tables (used in Session 2 contrast results) */
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    margin-bottom: var(--space-8);
  }

  .prose :global(th) {
    text-align: left;
    padding: var(--space-2) var(--space-4);
    border-bottom: 2px solid var(--color-border);
    color: var(--color-ink-muted);
    font-weight: 500;
    letter-spacing: 0.03em;
  }

  .prose :global(td) {
    padding: var(--space-2) var(--space-4);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-ink);
  }

  .prose :global(tr:last-child td) {
    border-bottom: none;
  }

  /* ── Previous / next navigation ───────────────────── */
  .entry-nav {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-8);
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .entry-nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    text-decoration: none;
    max-width: 45%;
    transition: opacity var(--duration-fast) var(--ease-standard);
  }

  .entry-nav-link:hover {
    opacity: 0.75;
  }

  .nav-next {
    margin-left: auto;
    text-align: right;
    align-items: flex-end;
  }

  .nav-label {
    font-size: var(--text-xs);
  }

  .nav-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.4;
  }
</style>
