---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'George Mitchell Payne',
  description = 'Learning engineer.',
} = Astro.props;

const currentPath = Astro.url.pathname;

const canonicalURL = new URL(currentPath, Astro.site);
const ogImageURL = new URL('/og-card.png', Astro.site);

const navLinks = [
  { href: '/builds',    label: 'Builds' },
  { href: '/log',       label: 'Log' },
  { href: '/practice',  label: 'Practice' },
  { href: '/analytics', label: 'Analytics' },
  { href: '/about',     label: 'About' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Social cards (Open Graph + Twitter) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="George Mitchell Payne" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="George Mitchell Payne — Learning Engineer. Three-circle Venn mark on a paper background." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Preconnect to reduce font load latency -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!--
      Display : Fraunces — optical variable serif, used sparingly for positioning lines
      Body    : Source Serif 4 — optical serif, high legibility for long-form reading
      Mono    : JetBrains Mono — the telemetry voice
      Load asynchronously to avoid render-blocking (noscript fallback for no-JS envs)
    -->
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,700;1,9..144,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=JetBrains+Mono:wght@400;500&display=swap"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,700;1,9..144,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=JetBrains+Mono:wght@400;500&display=swap"
        rel="stylesheet"
      />
    </noscript>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <div class="site-wrapper">
      <header class="site-header">
        <nav class="site-nav container" aria-label="Site navigation">
          <a href="/" class="nav-home" aria-label="George Mitchell Payne — home">George Mitchell Payne</a>
          <ul class="nav-links" role="list">
            {navLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  aria-current={currentPath === href ? 'page' : undefined}
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </header>

      <main id="main-content">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="footer-inner container">
          <p class="footer-copy">
            &copy; {new Date().getFullYear()} George Mitchell Payne
          </p>
          <ul class="footer-links" role="list">
            <li>
              <a href="https://github.com/GPayne12" rel="noopener noreferrer" aria-label="GitHub profile">
                GitHub
              </a>
            </li>
            <li>
              <a href="https://www.linkedin.com/in/georgemitchellpayne" rel="noopener noreferrer" aria-label="LinkedIn profile">
                LinkedIn
              </a>
            </li>
          </ul>
        </div>
      </footer>
    </div>

    <!-- xAPI page-view beacon (/analytics pipeline). Anonymous session id only;
         honors Do Not Track; production hostname only so the data is real
         visitors, never dev noise. Statement is built server-side in /api/xapi. -->
    <script is:inline>
      (function () {
        if (location.hostname !== 'www.georgemitchellpayne.com') return;
        if (navigator.doNotTrack === '1') return;
        var id = sessionStorage.getItem('xapi-session');
        if (!id) {
          id = Array.from(crypto.getRandomValues(new Uint8Array(8)))
            .map(function (b) { return b.toString(16).padStart(2, '0'); }).join('');
          sessionStorage.setItem('xapi-session', id);
        }
        var payload = JSON.stringify({ page: location.pathname, session: id });
        fetch('/api/xapi', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: payload,
          keepalive: true,
        }).catch(function () {});
      })();
    </script>
  </body>
</html>
